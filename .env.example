# ============================================================
# CatDiary 环境变量配置示例
# 复制此文件为 .env 并修改对应的值喵～
#   cp .env.example .env
# ============================================================

# ---------- 必填 ----------
# MySQL 连接串（格式：user:password@tcp(host:port)/dbname?charset=utf8mb4&parseTime=True&loc=Local）
CATDIARY_MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/catdiary?charset=utf8mb4&parseTime=True&loc=Local

# ---------- 可选：Redis ----------
# Redis 地址（默认 127.0.0.1:6379）
# CATDIARY_REDIS_ADDR=127.0.0.1:6379
# Redis 密码（默认空）
# CATDIARY_REDIS_PASSWORD=
# Redis 数据库编号（默认 0）
# CATDIARY_REDIS_DB=0

# ---------- 可选：安全 ----------
# JWT 签名密钥（生产环境务必修改为随机字符串！！！）
# JWT_SECRET=catdiary_default_secret_key_please_change

# ---------- 可选：其他 ----------
# 自定义 .env 文件路径（默认自动查找当前目录和上级目录的 .env）
# CATDIARY_ENV_FILE=/path/to/your/.env
